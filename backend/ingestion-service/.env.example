# ─── Hyperview Ingestion Service ───────────────────────────────
# Copy to .env and fill in your values

# Redis connection (Railway provides this automatically)
REDIS_URL=redis://default:password@redis-host:6379

# Port for the HTTP API (Railway sets this automatically)
PORT=3001

# Legacy Hyperview backend URL (for liquidation polling)
BACKEND_URL=https://hyperview-backend-production-075c.up.railway.app

# Hyperliquid endpoints (defaults are mainnet — override for testnet)
# HL_WS_URL=wss://api.hyperliquid.xyz/ws
# HL_INFO_URL=https://api.hyperliquid.xyz/info
